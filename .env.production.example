# ===== PRODUCCIÓN: copiar como .env y completar valores reales =====
# Todos los valores VITE_* se embeben en el bundle en build time.
# Ejecutar: npm run build -- --mode production

# URL base del backend Core (sin trailing slash, sin /core/v1).
# Ej: https://api.banquito.com
VITE_API_BASE_URL=https://api.banquito.com

# URL base del microservicio Switch (pagos masivos).
# Ej: https://switch.banquito.com
# OBLIGATORIO si se usan pagos masivos, si se omite esa sección fallará.
VITE_SWITCH_BASE_URL=https://switch.banquito.com

# URL base del microservicio SFTP (buzón de archivos).
# Ej: https://sftp.banquito.com
# OBLIGATORIO si se usa el módulo de archivos SFTP.
VITE_SFTP_BASE_URL=https://sftp.banquito.com

# ===== OPCIONALES =====
VITE_API_TIMEOUT=10000
VITE_APP_NAME=Banquito Intranet
VITE_ENVIRONMENT=production
VITE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=false
