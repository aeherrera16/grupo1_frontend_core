# ===== CONFIGURACIÓN DE BACKEND =====
# En desarrollo: http://localhost:8080/core/v1
# En producción: usa una URL absoluta (ej: https://api.banquito.com/core/v1)
# O usa una URL relativa para que el navegador use el mismo dominio que el frontend
VITE_API_BASE_URL=http://localhost:8080/core/v1
VITE_API_TIMEOUT=10000

# ===== CONFIGURACIÓN DE APP =====
VITE_APP_NAME=Banquito Intranet
VITE_ENVIRONMENT=development

# ===== CONFIGURACIÓN DE SEGURIDAD =====
# En producción, estos deben ser false
VITE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=false
